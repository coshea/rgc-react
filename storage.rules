rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated reads for internal images
    match /internal/{imageId} {
      allow read: if request.auth != null;
    }

    // Avatars: only the authenticated owner may write their avatar files.
    // Enforce size and content-type limits to prevent abuse.
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      // Limit reads to the owner; change to `if true` if you want public avatars.
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Blog images: only admins can write, but anyone can read
    match /blog-images/{imageId} {
      allow read: if true;
      // Verify admin status via custom claim OR admin document flag
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.isAdmin == true ||
        firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.admin == true
      ) && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Documents folder: authenticated users can read, admins can write
    match /docs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.isAdmin == true ||
        firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.admin == true
      );
    }

    // Public documents folder: anyone can read, only admins can write
    match /public-docs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.isAdmin == true ||
        firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.admin == true
      );
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
