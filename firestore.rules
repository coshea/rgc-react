rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: returns true if the requester is a super-admin (custom claim)
    // or is listed in the admin collection (/admin/{uid}.isAdmin == true).
    function isAdmin() {
      let adminDoc = get(/databases/$(database)/documents/admin/$(request.auth.uid));
      return request.auth != null && (
        // Custom claim OR explicit admin doc flags only
        request.auth.token.admin == true
        || adminDoc.data.isAdmin == true
        || adminDoc.data.admin == true
        || adminDoc.data.admin == 'true'
      );
    }

    // Helper: validates required fields for a blog post document
    function isValidBlogPost(post) {
      return post.title is string &&
             post.slug is string &&
             post.content is string &&
             post.authorId is string &&
             post.authorName is string &&
             post.status is string &&
             post.category is string &&
             post.createdAt is timestamp &&
             post.updatedAt is timestamp;
    }

    // Allow authenticated users to read the users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow users to write their own profile. Also allow admins to create or modify
      // other users' profiles (so admins can add members). Admin check uses custom
      // claim `request.auth.token.admin == true` or the admin collection lookup.
      function isSelfOrAdmin() {
        return request.auth != null && (
          request.auth.uid == userId || isAdmin()
        );
      }
      // Validate board fields: only admins may set boardMember true or assign a role.
      // Validate board fields only when boardMember asserted. Roles must be in the allow list.
      function boardRoleValid(newData) {
        let allowed = [
          'President',
          'Treasurer',
          'Handicap Chairman',
          'Tournament Chairman',
          'Webmaster',
          'Board Member'
        ];
        return !(newData.boardMember == true) || (
          newData.role is string && newData.role != '' && allowed.hasAny([newData.role])
        );
      }
      // Enforce minimal integrity: email must be present in the doc and a non-empty string on create.
      function hasBaselineFields(d) {
        return d.email is string && d.email != '';
      }
      // Core write gate with board field restrictions
      // Helper: ensure request doesn't change privileged board/admin fields
      function boardFieldsUnchanged(newData, oldData) {
        return (newData.boardMember == oldData.boardMember)
          && (newData.role == oldData.role);
      }
      // Permit admins to create any user doc; permit non-admin authenticated users to create
      // their own user doc (without board fields). Bulk upload relies on admin path.
      allow create: if request.auth != null && hasBaselineFields(request.resource.data) && (
        // Admin full create
        isAdmin() && boardRoleValid(request.resource.data)
        // Self-create with no board fields
        || (request.auth.uid == userId && request.resource.data.boardMember != true && !(request.resource.data.role is string))
      );
      // Updates
      // Admin path: can update any profile with board validation
      allow update: if request.auth != null && isAdmin() && boardRoleValid(request.resource.data);

      // Self-update path: can update own profile, but cannot change board/admin fields.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && boardFieldsUnchanged(request.resource.data, resource.data);
      allow delete: if isSelfOrAdmin();
    }

    // Example: allow public read of tournaments, but restrict writes to a whitelist or admins
    match /tournaments/{tournamentId} {
      // Public read of tournaments
      allow read: if true;
      // Only allow create/update/delete if the requester is an admin (either
      // has the custom claim or is listed in /admin/{uid}.isAdmin == true).
      allow create, update, delete: if isAdmin();
      // Registrations should be stored as documents under the subcollection
      // tournaments/{tournamentId}/registrations/{registrationId}
      // This keeps the server-side checks simpler and avoids arrayUnion/serverTimestamp issues.
      match /registrations/{registrationId} {
        // Create:
        // - Normal users: must be owner (ownerId == auth.uid) AND registrationOpen == true.
        // - Admins: may create regardless of registrationOpen; ownerId can be "__admin__" or their own uid.
        allow create: if request.auth != null
          && request.resource.data.team is list
          && request.resource.data.team.size() > 0
          && ( !(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.players is int)
               || request.resource.data.team.size() <= get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.players )
          && (
            (
              request.auth.uid == request.resource.data.ownerId &&
              get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.registrationOpen == true
            )
            || (
              isAdmin() && (
                request.resource.data.ownerId == "__admin__" || request.resource.data.ownerId == request.auth.uid
              )
            )
          );

        // Owner or admin can update or delete the registration. Use isAdmin()
        // so that admins defined under /admin/{uid} (isAdmin == true) are
        // permitted in addition to super-admin custom claims.
        allow update, delete: if request.auth != null && (
          request.auth.uid == resource.data.ownerId || isAdmin()
        );

  // Reading registrations: any authenticated user can read to view who is registered.
  // This broadens visibility from just owner/admin to all signed-in members.
  allow read: if request.auth != null;
      }
    }

  // find-a-game posts: members can create their own posts; owners or admins can update/delete; anyone can read
  match /findAGame/{postId} {
      // Public read of partner posts so members can browse without signing in
      allow read: if true;

      function isOwner() {
        return request.auth != null && resource != null && resource.data.ownerId == request.auth.uid;
      }

      function typeValid(d) {
        return d.type is string && ['needPlayers','needGroup'].hasAny([d.type]);
      }

      function dateValid(d) {
        return d.date is string && d.date != '';
      }

      function playersFieldsValid(d) {
        // For 'needPlayers': time is optional (can be null or string), openSpots required 1..3. For 'needGroup': time/openSpots should be absent or null.
        return (d.type == 'needPlayers' && (d.time == null || (d.time is string && d.time != '')) && d.openSpots is int && d.openSpots >= 1 && d.openSpots <= 3)
          || (d.type == 'needGroup' && (d.time == null || !(d.time is string)) && (d.openSpots == null || !(d.openSpots is int)));
      }

      // Owner must match auth on create; admins also allowed, but ownerId must equal auth.uid to keep clear ownership
      allow create: if request.auth != null
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == request.auth.uid
        && typeValid(request.resource.data)
        && dateValid(request.resource.data)
        && playersFieldsValid(request.resource.data);

      // Owner or admin may update; maintain ownerId stability; validate fields
      allow update: if request.auth != null && (isOwner() || isAdmin())
        && request.resource.data.ownerId == resource.data.ownerId
        && typeValid(request.resource.data)
        && dateValid(request.resource.data)
        && playersFieldsValid(request.resource.data);

      // Owner or admin may delete
      allow delete: if request.auth != null && (isOwner() || isAdmin());
    }

    // Admin list stored at /admin/{uid} with document { isAdmin: true }
    // Only super-admins (custom claim `admin == true`) can modify the admin list.
    // Admin documents can be read by the user themselves or by super-admins.
    match /admin/{adminId} {
      // Allow users to read their own admin doc (so client can check quickly)
      // IMPORTANT: cannot call isAdmin() here (would recurse). Only allow if user reads own doc or already has claim.
      allow read: if request.auth != null && (request.auth.uid == adminId || request.auth.token.admin == true);

      // Only custom-claim super-admins may create/update/delete admin documents.
      // This prevents arbitrary users from granting themselves admin rights.
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Membership payment records: /memberPayments/{userId_year}
    // Naming convention enforced at write time via client (userId_year). Rules here:
    // - Read: any authenticated user may read (to allow directory active status / profile views)
    // - Create: admins only. Creates are idempotent (client checks) but rules don't enforce idempotency.
    // - Update/Delete: admins only. Normal flow should rarely update except to correct status or refund.
    match /memberPayments/{paymentId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() && request.auth != null &&
        request.resource.data.userId is string &&
        request.resource.data.year is int &&
        request.resource.data.status in ['confirmed', 'pending', 'refunded'] &&
        request.resource.data.membershipType in ['full', 'handicap'];
      allow update: if isAdmin() &&
        request.resource.data.status in ['confirmed', 'pending', 'refunded'] &&
        request.resource.data.membershipType in ['full', 'handicap'];
      allow delete: if isAdmin();
    }

    // Championships collection for historical and modern championship records
    match /championships/{championshipId} {
      // Public read for displaying past champions
      allow read: if true;
      
      // Only admins can create/update/delete championship records
      allow create: if isAdmin() &&  
        request.resource.data.year is int &&  
        request.resource.data.championshipType is string &&  
        request.resource.data.winnerNames is list && request.resource.data.winnerNames.size() > 0 &&  
        (!('winnerIds' in request.resource.data) || request.resource.data.winnerIds is list) &&  
        (!('runnerUpNames' in request.resource.data) || request.resource.data.runnerUpNames is list) &&  
        (!('runnerUpIds' in request.resource.data) || request.resource.data.runnerUpIds is list) &&  
        request.resource.data.isHistorical is bool &&  
        request.resource.data.createdAt is timestamp &&  
        request.resource.data.updatedAt is timestamp; 
        
      allow update: if isAdmin() &&  
        request.resource.data.updatedAt is timestamp &&  
        (!('year' in request.resource.data) || request.resource.data.year is int) &&  
        (!('championshipType' in request.resource.data) || request.resource.data.championshipType is string) &&  
        (!('winnerNames' in request.resource.data) || (request.resource.data.winnerNames is list && request.resource.data.winnerNames.size() > 0)) &&  
        (!('isHistorical' in request.resource.data) || request.resource.data.isHistorical is bool);  





        
      allow delete: if isAdmin();
    }

    // Config collection: membership settings and other configuration
    match /config/{docId} {
      // Anyone authenticated can read config (needed for membership settings)
      allow read: if request.auth != null;
      
      // Only admins can write config
      allow write: if isAdmin();
    }

    // Blog posts collection
    match /blogPosts/{postId} {
      // Anyone can read published blog posts
      allow read: if resource.data.status == 'published' || isAdmin();  
      
      // Only admins can create, update, or delete blog posts
      allow create: if isAdmin() && isValidBlogPost(request.resource.data);
      
      allow update: if isAdmin() &&  
        request.resource.data.updatedAt is timestamp &&  
        request.resource.data.createdAt == resource.data.createdAt &&  
        request.resource.data.authorId == resource.data.authorId;
      
      allow delete: if isAdmin();
    }

    // Policies collection - admin-editable markdown documents
    match /policies/{policyType} {
      // Anyone can read policies
      allow read: if true;
      
      // Only admins can create or update policies
      allow create, update: if isAdmin() && 
        request.resource.data.type is string &&
        request.resource.data.title is string &&
        request.resource.data.content is string &&
        request.resource.data.updatedAt is timestamp &&
        request.resource.data.lastUpdatedBy is string &&
        request.resource.data.lastUpdatedByName is string;
      
      // Only admins can delete policies (but should be rare)
      allow delete: if isAdmin();
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
