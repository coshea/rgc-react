rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: returns true if the requester is a super-admin (custom claim)
    // or is listed in the admin collection (/admin/{uid}.isAdmin == true).
    function isAdmin() {
      return request.auth != null && (
        // custom claim override
        request.auth.token.admin == true
        // OR user has an admin document set to true
        || get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // Allow authenticated users to read the users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow users to write their own profile. Also allow admins to create or modify
      // other users' profiles (so admins can add members). Admin check uses custom
      // claim `request.auth.token.admin == true` or the admin collection lookup.
      function isSelfOrAdmin() {
        return request.auth != null && (
          request.auth.uid == userId || isAdmin()
        );
      }
      // Validate board fields: only admins may set boardMember true or assign a role.
      function boardRoleValid(newData) {
        let allowed = [
          'President',
          'Treasurer',
          'Handicap Chairman',
          'Webmaster',
          'Board Member'
        ];
        return !(newData.boardMember == true) || (
          newData.role is string && allowed.hasAny([newData.role])
        );
      }
      function boardFieldsUnchanged() {
        return resource == null || (
          resource.data.boardMember == request.resource.data.boardMember &&
          resource.data.role == request.resource.data.role
        );
      }
      // Core write gate with board field restrictions
      allow create: if isSelfOrAdmin() && boardRoleValid(request.resource.data) && (
        // if non-admin creating their own doc, they must not set board fields
        isAdmin() || (request.resource.data.boardMember != true && !(request.resource.data.role is string))
      );
      allow update: if isSelfOrAdmin() && boardRoleValid(request.resource.data) && (
        isAdmin() || boardFieldsUnchanged()
      );
      allow delete: if isSelfOrAdmin();
    }

    // Example: allow public read of tournaments, but restrict writes to a whitelist or admins
    match /tournaments/{tournamentId} {
      // Public read of tournaments
      allow read: if true;
      // Only allow create/update/delete if the requester is an admin (either
      // has the custom claim or is listed in /admin/{uid}.isAdmin == true).
      allow create, update, delete: if isAdmin();
      // Registrations should be stored as documents under the subcollection
      // tournaments/{tournamentId}/registrations/{registrationId}
      // This keeps the server-side checks simpler and avoids arrayUnion/serverTimestamp issues.
      match /registrations/{registrationId} {
        // Create:
        // - Normal users: must be owner (ownerId == auth.uid) AND registrationOpen == true.
        // - Admins: may create regardless of registrationOpen; ownerId can be "__admin__" or their own uid.
        allow create: if request.auth != null
          && request.resource.data.team is list
          && request.resource.data.team.size() > 0
          && ( !(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.players is int)
               || request.resource.data.team.size() <= get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.players )
          && (
            (
              request.auth.uid == request.resource.data.ownerId &&
              get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.registrationOpen == true
            )
            || (
              isAdmin() && (
                request.resource.data.ownerId == "__admin__" || request.resource.data.ownerId == request.auth.uid
              )
            )
          );

        // Owner or admin can update or delete the registration. Use isAdmin()
        // so that admins defined under /admin/{uid} (isAdmin == true) are
        // permitted in addition to super-admin custom claims.
        allow update, delete: if request.auth != null && (
          request.auth.uid == resource.data.ownerId || isAdmin()
        );

  // Reading registrations: any authenticated user can read to view who is registered.
  // This broadens visibility from just owner/admin to all signed-in members.
  allow read: if request.auth != null;
      }
    }

    // Admin list stored at /admin/{uid} with document { isAdmin: true }
    // Only super-admins (custom claim `admin == true`) can modify the admin list.
    // Admin documents can be read by the user themselves or by super-admins.
    match /admin/{adminId} {
      // Allow users to read their own admin doc (so client can check quickly)
      allow read: if request.auth != null && (request.auth.uid == adminId || request.auth.token.admin == true || isAdmin());

      // Only custom-claim super-admins may create/update/delete admin documents.
      // This prevents arbitrary users from granting themselves admin rights.
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
