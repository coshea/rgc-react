# Environment Variables
# Copy this file to .env.local and fill in your actual values

# EmailJS Configuration
# Get these from https://dashboard.emailjs.com/admin
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_PAYPAL_ENVIRONMENT=your_paypal_environment_here
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Sentry (Client/runtime)
# DSN is public (safe to ship to the browser), but keep auth tokens out of Vite env vars.
VITE_SENTRY_DSN=your_sentry_dsn_here

# Enable Sentry locally (production is always enabled)
VITE_SENTRY_ENABLE_IN_DEV=false

# Privacy: only enable if you have user consent + a policy in place
VITE_SENTRY_SEND_DEFAULT_PII=false

# Performance monitoring
# 1.0 = 100% sampling, 0.1 = 10% sampling
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# Comma-separated list of hosts/URLs for distributed tracing (strings only)
# Example: localhost,https://yourserver.io/api
VITE_SENTRY_TRACE_PROPAGATION_TARGETS=localhost

# Session Replay
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Enable logs to be sent to Sentry
VITE_SENTRY_ENABLE_LOGS=true