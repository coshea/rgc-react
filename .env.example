# Environment Variables
# Copy this file to .env.local and fill in your actual values

# EmailJS Configuration
# Get these from https://dashboard.emailjs.com/admin
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_PAYPAL_ENVIRONMENT=your_paypal_environment_here
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Firebase HTTP Functions base URL (used by endpoints like merge_user_ids and verify-and-record-membership-payment)
# Example: https://us-central1-ridgefield-golf-club.cloudfunctions.net
VITE_FIREBASE_FUNCTIONS_BASE_URL=your_firebase_functions_base_url_here